-- Expected: parse-clean (zero diagnostics + lossless round-trip)
-- Spec: function declarations §5.2, clause guards §5.3, block expressions §6.4
-- Clause guards (`if` in `::` clauses) and block expressions with local bindings.
-- Note: match-arm guards are NOT yet implemented; only :: clause guards work.

sign :: Int -> [#pos; #neg; #zero;]
     :: n if n > 0 { #pos }
     :: n if n < 0 { #neg }
     :: _          { #zero }

clamp :: Int -> Int -> Int -> Int
      :: lo -> hi -> x if x < lo { lo }
      :: lo -> hi -> x if x > hi { hi }
      :: _  -> _  -> x           { x }

safe_div :: Int -> Int -> Int?
         :: _ -> 0 { none }
         :: a -> b { a / b }

-- guard on a variant pattern
Result :: type [
  (#ok, val : Int);
  (#err, code : Int);
]

unwrap_pos :: Result -> Int -> Int
           :: (#ok, val = v) -> _ if v > 0 { v }
           :: (#ok, val = _) -> fallback   { fallback }
           :: (#err, code = _) -> fallback { fallback }

-- multiple local bindings in a block body
sum_of_squares :: Int -> Int -> Int -> Int
               :: a -> b -> c {
                 a2 := a * a;
                 b2 := b * b;
                 c2 := c * c;
                 a2 + b2 + c2
               }

-- block expression as the RHS of an inferred binding (BLOCK node, not RECORD_EXPR)
nested_blocks := {
  inner := { x := 3; y := 4; x + y };
  inner * 2
}

-- guard combined with a block body (local bindings inside a guarded clause)
abs :: Int -> Int
    :: n if n < 0 { neg := n * -1; neg }
    :: n          { n }

-- multi-argument clause with guard
between :: Int -> Int -> Int -> Bool
        :: lo -> hi -> x if x >= lo && x <= hi { true }
        :: _  -> _  -> _                        { false }

-- guard referencing a bound pattern variable
first_positive :: Int -> Int -> Int?
               :: a -> _ if a > 0 { a }
               :: _ -> b if b > 0 { b }
               :: _ -> _          { none }

-- chained local bindings, guard uses an outer param
norm :: Int -> Int -> Int
     :: a -> b {
       sum  := a + b;
       diff := a + (b * -1);
       if sum > 0 then diff else sum
     }

{
  sign_pos  = sign 5;
  sign_neg  = sign (-3);
  sign_zero = sign 0;
  clamped   = clamp 0 10 15;
  sumsq     = sum_of_squares 1 2 3;
  nested    = nested_blocks;
  absolute  = abs (-7);
  in_range  = between 1 10 5;
  first_pos = first_positive (-1) 3;
}
