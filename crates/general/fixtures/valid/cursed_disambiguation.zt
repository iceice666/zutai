-- cursed_disambiguation.zt: valid but awkward syntax around type/value contexts.

Tagged :: type {
  #empty;
  #single: { value: Int; };
  #recorded: { item: {
    plain : Text;
    optional-field? : Int?;
    hyphen-name : Bool;
  }; };
}

Callbacks :: type {
  direct : Int -> Int;
  wrapped? : (Int -> Int)?;
  choice : {#left; #right; #other: { label: Text; };};
  nested? : {
    tag : Tagged;
    next? : Tagged?;
  };
}

identity :: <A> A -> A
  = x => x;

choose :: Bool -> Int -> Int -> Int
  = true yes _ => yes;
  = false _ no => no;

wrap value = #single { value = value; }

{
  empty-record = {};
  block-inside-record = {
    local := choose true 10 20;
    wrap local
  };
  recorded-val = #recorded { item = {
    plain = "text";
    optional-field = #none;
    hyphen-name = false;
  }; };
  type-value = type {
    field : Tagged;
    callback? : (Int -> Int)?;
  };
  callbacks = {
    direct = \x. identity x;
    wrapped = #none;
    choice = #other { label = "fallback"; };
    nested = #none;
  };
}
