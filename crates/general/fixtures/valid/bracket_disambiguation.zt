-- Expected: parse-clean (zero diagnostics + lossless round-trip)
-- Spec: declarations §5, type exprs §11.3, records §10, unions §16, tagged unions §17
-- Three-bracket taxonomy edge cases: {}, [], () disambiguation.

-- [A] is a type-param list — comma-only, no `;` at depth 1
identity :: [A] A -> A
         :: x { x }

-- [A, B] multi-param type list
const_fst :: [A, B] A -> B -> A
          :: a -> _ { a }

-- [Int;] is a single-variant union type — `;` at depth 1 distinguishes it from [Int]
box_int :: Int -> [Int;]
        :: x { x }

-- [A;] generic single-variant union (type variable in union position)
rewrap :: [A] [A;] -> A
       :: x { x }

-- atom-set union (all bare atoms)
Dir :: type [#n; #s; #e; #w;]

dir_flip :: Dir -> Dir
         :: #n { #s }
         :: #s { #n }
         :: #e { #w }
         :: #w { #e }

-- named type record definition  (type-record syntax: fields use `:`)
Point :: type { x : Int; y : Int; }

-- inline type-record annotation (same syntax in `: TypeExpr =` position)
origin : { x : Int; y : Int; } = { x = 0; y = 0; }

-- annotated with named type (value record: fields use `=`)
shifted : Point = { x = 3; y = 4; }

-- block expression: `{ Ident := Expr ; … Expr }` — a BLOCK, not a RECORD_EXPR
sum_block := { a := 10; b := 20; a + b }

-- block used as clause body returning a value record
make_point :: Int -> Int -> Point
           :: px -> py { { x = px; y = py; } }

-- empty value record and empty list
e_rec : {} = {}
e_list : List Int = []

-- empty tuple pattern `()` in a clause — valid as pattern, not as expression/type
nullary :: Int -> Int
        :: () { 0 }
        :: n  { n }

-- shape with both variant tuples and a bare atom in the same union
Shape :: type [
  (#circle, radius : Float);
  (#rect, w : Float, h : Float);
  #none;
]

-- function returning a union type containing a variant
wrap_shape :: Float -> Shape
           :: r { (#circle, radius = r) }

-- nested type-param list vs nested union type in consecutive sigs
triple :: [A, B, C] A -> B -> C -> A
       :: a -> _ -> _ { a }

Tri :: type [#one; #two; #three;]

{
  id_int    = identity 42;
  fst_ab    = const_fst true 99;
  boxed     = box_int 7;
  rewrapped = rewrap 5;
  flipped   = dir_flip #n;
  summed    = sum_block;
  ox        = origin.x;
  sx        = shifted.x;
  mp        = make_point 1 2;
  shape     = wrap_shape 2.5;
  three_a   = triple #one #two #three;
}
