-- higher_order_functions.zt: Higher-order functions, composition, currying.

compose :: <A, B, C> (B -> C) -> (A -> B) -> A -> C {
  | f g x => f (g x);
}

flip :: <A, B, C> (A -> B -> C) -> B -> A -> C {
  | f b a => f a b;
}

applyTwice :: <A> (A -> A) -> A -> A {
  | f x => f (f x);
}

inc :: Int -> Int {
  | n => n + 1;
}

double :: Int -> Int {
  | n => n * 2;
}

negate :: Bool -> Bool {
  | true => false;
  | false => true;
}

{
  inc-then-double = compose double inc 3;
  twice-inc       = applyTwice inc 10;
  twice-double    = applyTwice double 3;
  twice-negate    = applyTwice negate true;
  flipped-add     = flip (\a b. a + b) 10 20;
  pipeline        = 5 |> inc |> double |> applyTwice inc;
  lambda-compose  = compose (\n. n * n) (\n. n + 1) 4;
}
