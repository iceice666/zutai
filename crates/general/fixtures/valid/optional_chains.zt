Addr :: type { host : Text; port : Int; }

Conn :: type {
  addr?  : Addr;
  tls?   : Bool;
  retry? : Int;
}

Config :: type {
  primary?   : Conn;
  secondary? : Conn;
  timeout    : Int;
}

Cluster :: type {
  leader?  : Config;
  replica? : Config;
  name     : Text;
}

RawAddr :: type { host? : Text; port? : Int; }

RawConn :: type {
  addr?   : RawAddr;
  tls?    : Bool?;
  retry?  : Int?;
}

get_host :: Config? -> Text
         :: c { c?.primary?.addr?.host ?? c?.secondary?.addr?.host ?? "0.0.0.0" }

get_port :: Config? -> Int
         :: c { c?.primary?.addr?.port ?? c?.secondary?.addr?.port ?? 80 }

get_tls :: Config? -> Bool
        :: c { c?.primary?.tls ?? c?.secondary?.tls ?? false }

chain_of_five :: Cluster? -> Text
              :: cl {
                cl?.leader?.primary?.addr?.host
                  ?? cl?.leader?.secondary?.addr?.host
                  ?? cl?.replica?.primary?.addr?.host
                  ?? cl?.replica?.secondary?.addr?.host
                  ?? "fallback"
              }

double_default :: Int? -> Int? -> Int? -> Int
               :: a -> b -> c { a ?? b ?? c ?? 0 }

right_assoc_chain :: Int? -> Int? -> Int? -> Int? -> Int? -> Int
                  :: a -> b -> c -> d -> e { a ?? b ?? c ?? d ?? e ?? -1 }

flatten :: (Int?)? -> Int?
        :: none { none }
        :: x    { x }

optional_arithmetic :: Int? -> Int? -> Int
                    :: none -> b { b ?? 0 }
                    :: a -> none { a ?? 0 }
                    :: a -> b    { (a ?? 0) + (b ?? 0) }

normalize_addr :: RawConn? -> Addr
              :: raw {
                host := raw?.addr?.host ?? "127.0.0.1";
                port := raw?.addr?.port ?? 8080;
                { host = host; port = port; }
              }

absent_is_none :: Conn? -> Bool
              :: none { true }
              :: c    { match c?.tls { none => true; _ => false; } }

optional_in_match :: Int? -> Text
                  :: none  { "absent" }
                  :: x     { match x ?? 0 { 0 => "zero"; _ => "nonzero"; } }

double_opt_field :: Config? -> Text
                 :: c {
                   match c?.primary?.addr {
                     none   => c?.secondary?.addr?.host ?? "none";
                     addr   => addr.host;
                   }
                 }

chained_defaults :: Cluster? -> Int
                 :: cl {
                   cl?.leader?.timeout
                     ?? cl?.replica?.timeout
                     ?? 30
                 }

dbl : (Int?)? = 42

unwrapped_dbl := dbl ?? none ?? 0

cfg : Config = {
  primary = {
    addr  = { host = "db.internal"; port = 5432; };
    tls   = true;
    retry = 3;
  };
  secondary = none;
  timeout = 30;
}

cl : Cluster = {
  leader  = cfg;
  replica = none;
  name    = "main";
}

{
  host         = get_host cfg;
  port         = get_port cfg;
  tls          = get_tls cfg;
  chain5       = chain_of_five cl;
  dbl_default  = double_default none none 42;
  right_chain  = right_assoc_chain none none none none 7;
  flattened    = flatten dbl;
  absent_tls   = cfg.secondary?.tls ?? false;
  absent_retry = cfg.secondary?.retry ?? 0;
  normed       = normalize_addr none;
  chained_to   = chained_defaults cl;
}
