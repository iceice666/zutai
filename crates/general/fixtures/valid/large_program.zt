-- large_program.zt: Many declarations — stress test for parser and HIR lowering.

LogLevel :: type {
  #debug;
  #info;
  #warn;
  #error;
}

ServiceConfig :: type {
  host : Text;
  port : Int;
  tls : Bool?;
  max-connections : Int?;
  timeout-ms : Int?;
}

AppConfig :: type {
  name : Text;
  version : Text;
  log-level : LogLevel;
  primary-service : ServiceConfig;
  fallback-service : ServiceConfig?;
  debug-mode : Bool?;
}

identity :: <A> A -> A {
  | x => x;
}

constFn :: <A, B> A -> B -> A {
  | a _ => a;
}

flip :: <A, B, C> (A -> B -> C) -> B -> A -> C {
  | f b a => f a b;
}

compose :: <A, B, C> (B -> C) -> (A -> B) -> A -> C {
  | f g x => f (g x);
}

applyIf :: Bool -> (Int -> Int) -> Int -> Int {
  | true f x  => f x;
  | false _ x => x;
}

logLevelValue :: LogLevel -> Int {
  | #debug => 0;
  | #info  => 1;
  | #warn  => 2;
  | #error => 3;
}

isAtLeast :: LogLevel -> LogLevel -> Bool {
  | target level => logLevelValue level >= logLevelValue target;
}

shouldLog :: AppConfig -> LogLevel -> Bool {
  | cfg level => isAtLeast cfg.log-level level;
}

defaultPort :: ServiceConfig -> Int {
  | svc => svc.port;
}

effectiveTimeout :: ServiceConfig -> Int {
  | svc => svc.timeout-ms ?? 5000;
}

maxConnections :: ServiceConfig -> Int {
  | svc => svc.max-connections ?? 100;
}

isSecure :: ServiceConfig -> Bool {
  | svc => svc.tls ?? false;
}

debugMode :: AppConfig -> Bool {
  | cfg => cfg.debug-mode ?? false;
}

inc :: Int -> Int {
  | n => n + 1;
}

double :: Int -> Int {
  | n => n * 2;
}

square :: Int -> Int {
  | n => n * n;
}

clamp :: Int -> Int -> Int -> Int {
  | lo hi n => match (n < lo) {
      | true => lo;
      | false => match (n > hi) {
          | true => hi;
          | false => n;
        };
    };
}

primary :: ServiceConfig = {
  host = "api.example.com";
  port = 443;
  tls = #none;
  max-connections = #none;
  timeout-ms = #none;
}

appCfg :: AppConfig = {
  name = "my-service";
  version = "1.0.0";
  log-level = #info;
  primary-service = primary;
  fallback-service = #none;
  debug-mode = #none;
}

{
  lvl-debug  = logLevelValue #debug;
  lvl-info   = logLevelValue #info;
  lvl-warn   = logLevelValue #warn;
  lvl-error  = logLevelValue #error;
  log-info   = shouldLog appCfg #info;
  log-debug  = shouldLog appCfg #debug;
  port       = defaultPort primary;
  timeout    = effectiveTimeout primary;
  conns      = maxConnections primary;
  secure     = isSecure primary;
  debug      = debugMode appCfg;
  n1         = clamp 0 10 (-5);
  n2         = clamp 0 10 5;
  n3         = clamp 0 10 15;
  pipeline   = 3 |> inc |> double |> square;
  applied    = applyIf true double 7;
  composed   = compose double inc 4;
  flipped    = flip (\a b. a - b) 3 10;
  const-val  = constFn "fixed" 42;
  id-val     = identity 99;
}
