-- deep_optionals.zt: Optional fields, null-coalescing, and optional types.

Server :: type {
  host : Text;
  port : Int;
};

Config :: type {
  server? : Server;
  retries? : Int;
  label? : Text;
};

defaultHost :: Config -> Text
  = c => c.server?.host ?? "localhost";

defaultPort :: Config -> Int
  = c => c.server?.port ?? 8080;

withRetries :: Config -> Int
  = c => c.retries ?? 3;

withLabel :: Config -> Text
  = c => c.label ?? "none";

orZero :: Int? -> Int
  = n => n ?? 0;

emptyCfg :: Config = {};

fullCfg :: Config = {
  server = { host = "example.com"; port = 443; };
  retries = 5;
  label = "prod";
};

explicitNone :: Int? = #none;
explicitSome :: Int? = #some (42);

{
  host1     = defaultHost emptyCfg;
  port1     = defaultPort emptyCfg;
  retries1  = withRetries emptyCfg;
  label1    = withLabel emptyCfg;
  host2     = defaultHost fullCfg;
  port2     = defaultPort fullCfg;
  zero1     = orZero #none;
  some1     = orZero explicitSome;
  coalesce1 = explicitNone ?? 7;
  coalesce2 = explicitSome ?? 7;
  chain1    = emptyCfg.server?.host ?? "fallback";
  chain2    = fullCfg.server?.port ?? 0;
}
