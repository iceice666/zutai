-- Expected: parse-clean (zero diagnostics + lossless round-trip)
-- Spec: records §10, unions §16, tagged unions §17, operator-precedence.md
-- Nests records, unions, tagged unions, and operator expressions deeply to stress
-- the recursive descent paths and precedence climbing.

Tree :: type [
  (#leaf);
  (#node, value : Int, left : Tree, right : Tree);
]

Forest :: type [
  (#empty);
  (#cons, head : Tree, tail : Forest);
]

Pair :: type [
  (#pair, fst : Int, snd : Int);
]

Result :: type [
  (#ok, value : Int);
  (#err, code : Int, message : Text);
]

NestedBox :: type {
  inner : {
    deeper : {
      value  : Int;
      label  : Text;
      flags  : [#a; #b; #c;];
    };
    alt : Int?;
  };
  tag : [#box; #container; #wrapper;];
}

tree_sum :: Tree -> Int
         :: (#leaf) { 0 }
         :: (#node, value = v, left = l, right = r) { v + tree_sum l + tree_sum r }

tree_depth :: Tree -> Int
           :: (#leaf) { 0 }
           :: (#node, value = _, left = l, right = r) {
             ld := tree_depth l;
             rd := tree_depth r;
             1 + (if ld > rd then ld else rd)
           }

forest_sum :: Forest -> Int
           :: (#empty) { 0 }
           :: (#cons, head = t, tail = rest) { tree_sum t + forest_sum rest }

maybe_pair :: Tree -> Pair?
           :: (#leaf) { none }
           :: (#node, value = v, left = (#node, value = lv, left = _, right = _), right = _) {
             (#pair, fst = lv, snd = v)
           }
           :: (#node, value = v, left = _, right = (#node, value = rv, left = _, right = _)) {
             (#pair, fst = v, snd = rv)
           }
           :: _ { none }

deep_match :: Tree -> Tree -> [#both_leaves; #left_leaf; #right_leaf; #balanced; #left_heavy; #right_heavy;]
           :: (#leaf) -> (#leaf) { #both_leaves }
           :: (#leaf) -> _ { #left_leaf }
           :: _ -> (#leaf) { #right_leaf }
           :: (#node, value = _, left = (#leaf), right = (#leaf)) -> (#node, value = _, left = (#leaf), right = (#leaf)) { #balanced }
           :: (#node, value = _, left = l1, right = r1) -> (#node, value = _, left = l2, right = r2) {
             s1 := tree_sum l1 + tree_sum r1;
             s2 := tree_sum l2 + tree_sum r2;
             if s1 == s2 then #balanced else if s1 > s2 then #left_heavy else #right_heavy
           }

apply_n :: [A] (A -> A) -> Int -> A -> A
        :: _ -> 0 -> x { x }
        :: f -> n -> x { apply_n f (n + -1) (f x) }

compose3 :: [A, B, C, D] (C -> D) -> (B -> C) -> (A -> B) -> A -> D
         :: h -> g -> f -> x { h (g (f x)) }

on :: [A, B, C] (B -> B -> C) -> (A -> B) -> A -> A -> C
   :: op -> f -> x -> y { op (f x) (f y) }

zip_trees :: Tree -> Tree -> Tree
          :: (#leaf) -> r { r }
          :: l -> (#leaf) { l }
          :: (#node, value = v1, left = l1, right = r1) -> (#node, value = v2, left = l2, right = r2) {
            (#node, value = v1 + v2, left = zip_trees l1 l2, right = zip_trees r1 r2)
          }

nested_pipeline :: Tree -> Int
               :: t {
                 t
                   |> tree_sum
                   |> (\n => n * 2 + 1)
                   |> (\n => apply_n (\x => x + 3) 4 n)
                   |> (\n => if n > 100 then 100 else n)
               }

classify_result :: Result -> [#success; #client_error; #server_error;]
               :: (#ok, value = _)        { #success }
               :: (#err, code = c, message = _) {
                 if c >= 500 then #server_error else if c >= 400 then #client_error else #server_error
               }

deeply_nested_if :: Tree -> [#huge; #big; #medium; #small; #tiny;]
                 :: t {
                   s := tree_sum t;
                   d := tree_depth t;
                   if s > 1000
                   then #huge
                   else if s > 100
                        then if d > 5 then #big else #medium
                        else if s > 10
                             then if d > 3 then #medium else #small
                             else #tiny
                 }

leaf := (#leaf)
t1 := (#node, value = 1, left = (#leaf), right = (#leaf))
t2 := (#node, value = 2, left = (#node, value = 3, left = (#leaf), right = (#leaf)), right = (#leaf))
t3 := (#node, value = 4, left = t1, right = t2)
t4 := (#node, value = 5, left = t3, right = (#node, value = 6, left = t2, right = t1))

f1 : Forest = (#cons, head = t1, tail = (#cons, head = t2, tail = (#cons, head = t3, tail = (#empty))))

nested_box : NestedBox = {
  inner = {
    deeper = {
      value = 99;
      label = "deep";
      flags = #c;
    };
    alt = 7;
  };
  tag = #container;
}

{
  t4_sum      = tree_sum t4;
  t4_depth    = tree_depth t4;
  f1_sum      = forest_sum f1;
  matched     = deep_match t3 t4;
  paired      = maybe_pair t2;
  zipped_sum  = tree_sum (zip_trees t3 t4);
  pipeline    = nested_pipeline t4;
  classified  = deeply_nested_if t4;
  box_val     = nested_box.inner.deeper.value;
  box_label   = nested_box.inner.deeper.label;
}
