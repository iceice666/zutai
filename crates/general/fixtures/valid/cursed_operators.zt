-- cursed_operators.zt: dense precedence, application, access, and pipeline forms.

inc :: Int -> Int {
  | n => n + 1;
}

double :: Int -> Int {
  | n => n * 2;
}

applyTwice :: (Int -> Int) -> Int -> Int {
  | f x => f (f x);
}

unwrapOr :: Int? -> Int -> Int {
  | n d => n ?? d;
}

Server :: type {
  host-name : Text;
  port : Int;
  tls : Bool?;
}

Config :: type {
  server : Server;
  limits : List Int;
}

cfg :: Config = {
  server = {
    host-name = "localhost";
    port = 8080;
    tls = #some { value = false; };
  };
  limits = [0; -1; 2 * 3 + 4 / 2;];
}

{
  arithmetic = ((1 + 2) * (3 + 4)) / (5 - 2);
  comparison = (1 + 2 * 3 == 7) && (4 <= 4) || false;
  coalesce = cfg.server.tls ?? false;
  access = cfg.server.host-name;
  forward-pipeline =
    3
    |> inc
    |> double
    |> applyTwice inc;
  backward-pipeline =
    applyTwice double
    <| inc 5;
  lambda-application = (\f x. f (x + 1)) (\n. n * n) 4;
  nested-block = {
    first := inc (double 2);
    second := unwrapOr #some { value = first; } 0;
    first + second
  };
}
