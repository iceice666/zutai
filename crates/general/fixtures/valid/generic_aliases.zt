-- generic_aliases.zt: Parametric type aliases and generic functions.

Pair :: <A, B> type {
  first : A;
  second : B;
}

Box :: <A> type {
  value : A;
}

Either :: <A, B> type {
  #left: { value: A; };
  #right: { value: B; };
}

fst :: <A, B> Pair A B -> A {
  | p => p.first;
}

snd :: <A, B> Pair A B -> B {
  | p => p.second;
}

swap :: <A, B> Pair A B -> Pair B A {
  | p => { first = p.second; second = p.first; };
}

unbox :: <A> Box A -> A {
  | b => b.value;
}

mapBox :: <A, B> (A -> B) -> Box A -> Box B {
  | f b => { value = f b.value; };
}

isLeft :: <A, B> Either A B -> Bool {
  | #left { value = _; } => true;
  | #right { value = _; } => false;
}

intPair :: Pair Int Int = { first = 1; second = 2; }
strPair :: Pair Text Text = { first = "hello"; second = "world"; }
mixedPair :: Pair Int Bool = { first = 42; second = true; }
boxedInt :: Box Int = { value = 100; }
boxedText :: Box Text = { value = "wrapped"; }
leftVal :: Either Int Text = #left { value = 1; }
rightVal :: Either Int Text = #right { value = "ok"; }

{
  x           = fst intPair;
  y           = snd strPair;
  swapped     = swap intPair;
  raw         = unbox boxedInt;
  doubled-box = mapBox (\n. n * 2) boxedInt;
  mixed-first = fst mixedPair;
  wrapped     = unbox boxedText;
  is-left     = isLeft leftVal;
  is-right    = isLeft rightVal;
}
