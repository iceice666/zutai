-- cursed_patterns.zt: clause parsing, guards, nested matches, and field patterns.

MaybeInt :: type {
  #empty;
  #filled: { value: Int; };
};

Packet :: type {
  status : {#ok; #err; #pending;};
  payload : MaybeInt;
  meta : {
    retry_count : Int;
    label : Text?;
  };
};

unwrapOr :: MaybeInt -> Int -> Int
  = #empty fallback => fallback;
  = #filled { value = value; } _ => value;

classify :: Int -> Text
  = n if n > 0 => "positive";
  = 0 => "zero";
  = _ => "negative";

describe :: Packet -> Text
  = { status = #ok; payload = #filled { value = n; }; meta = { retry_count = 0; label = #none; }; } =>
      classify n;
  = { status = #ok; payload = #empty; meta = _; } =>
      "empty-ok";
  = { status = #err; payload = value; meta = { retry_count = retries; label = _; }; } =>
      match retries {
        | 0 => "fresh-error";
        | n if n > 3 => "stale-error";
        | _ => classify (unwrapOr value -1);
      };
  = _ => "pending";

sample :: Packet = {
  status = #err;
  payload = #filled { value = -2; };
  meta = {
    retry_count = 2;
    label = #none;
  };
};

{
  result = describe sample;
  fallback = unwrapOr #empty 99;
}
