-- Type-grammar corners: optionals, nested type forms, function types inside types.

-- Double-optional: `T??` in type position is `(T?)?` (single QUESTION_QUESTION token)
double_opt_ann : Int?? = none

-- Explicit parenthesised double-optional: `(T?)?` — same semantics, different parse path
explicit_double : (Int?)? = 42

-- Triple optional via `??` twice would not parse (third `?` appended), so two:
-- `(Int?)?` is as deep as the spec encourages.

-- Optional field: `field? : T` — the field may be absent
Conn :: type {
  host? : Text;
  port  : Int;
  tls?  : Bool;
}

-- Optional field with optional value: `field? : T?` — absent OR none when present
RawConn :: type {
  host?  : Text?;
  port?  : Int?;
  retry? : Int??;
}

-- Function type as a field type (no `type` keyword in nested position)
Handler :: type {
  on-success : Int -> Text;
  on-failure : Text -> Int -> Bool;
}

-- Nested record type (no `type` keyword in nested position — just `{...}`)
Pair :: type {
  left  : { val : Int; tag : Text; };
  right : { val : Int; tag : Text; };
}

-- Nested union type in a record field
Tagged :: type {
  status : [#ok; #err; #pending;];
  code?  : Int;
}

-- Function taking/returning optional types
wrap :: Int? -> Text? -> Int?
     :: none -> _ { none }
     :: x -> _ { x }

coalesce3 :: Int? -> Int? -> Int? -> Int
          :: a -> b -> c { a ?? b ?? c ?? 0 }

-- Optional in union item
MaybeNum :: type [Int?; Text;]

-- Function type in union item
Callback :: type [Int -> Bool; Text -> Int;]

-- `??` in an annotated binding type (double-optional shorthand)
fallback_val : Int?? = none

-- Optional return type with nullable function type in a record
Api :: type {
  handler? : Int -> Int?;
  name     : Text;
}

-- Deeply optional chain in a function signature
deep_opt :: (Int?)? -> (Int?)? -> (Int?)?
         :: none -> b { b }
         :: a -> _ { a }

{
  double_opt_ann = double_opt_ann;
  explicit_double = explicit_double;
  fallback_val = fallback_val;
  coalesced = coalesce3 none none 7;
  deep = deep_opt none (42);
}
