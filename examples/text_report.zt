-- Text reporting example
-- Usage: zutai-cli run examples/text_report.zt
-- Splits, normalizes, replaces, joins, and parses text.

use stdlib {
  text as t;
  optional as o;
}

raw ::= " zutai,examples,zt ";
parts ::= t.split "," (t.trim raw);
upper ::= t.toUpper (t.join " | " parts);
patched ::= t.replace "ZT" "Zutai" upper;
parsed ::= o.withDefault 0 (t.parseInt "42");

{
  title = patched;
  containsExamples = t.contains "EXAMPLES" patched;
  length = t.length patched;
  parsed =;
}
