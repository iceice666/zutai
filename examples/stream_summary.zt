-- Stream/list summary example
-- Usage: zutai-cli run examples/stream_summary.zt
-- Adapts a list to a stream, transforms it lazily, and summarizes it.

s ::= import stdlib.stream;

numbers ::= {1; 2; 3; 4; 5; 6;};

doubledEvens ::= numbers
  |> s.fromList
  |> s.filter (\x. x % 2 == 0)
  |> s.map (\x. x * 2)
  |> s.take 3;

sum ::= s.fold (\acc x. acc + x) 0 doubledEvens;
items ::= s.toList doubledEvens;

{
  items =;
  sum =;
  count = length items;
}
