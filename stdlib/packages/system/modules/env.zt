-- Explicit environment lookup helper over the existing host effect.
-- Explicit import only: `env ::= import stdlib.env`; these names are not ambient.
GetEffects :: type Unit ! { env.get : Text -> Text?; };
Get :: <A> type A ! { * GetEffects; };
get :: Env -> Text -> Get Text?
  = env name => perform env.get name;
{ get = get; }
